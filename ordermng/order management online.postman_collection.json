                  "    pm.expect(pm.response.code).to.eql(201);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "\r",
                  "const schema = {\r",
                  "    \"type\" : \"object\",\r",
                  "    \"properties\" : {\r",
                  "        \"order\" : {\r",
                  "            \"type\": \"object\",\r",
                  "            \"properties\" : {\r",
                  "                \"id\" : {\r",
                  "                 \"type\" : \"string\"\r",
                  "                },\r",
                  "                \"customer\":{\r",
                  "                \"type\": \"string\"\r",
                  "                },\r",
                  "                \"items\": {\r",
                  "                \"type\" : \"array\",\r",
                  "                \"properties\":{\r",
                  "                \"productId\": {\r",
                  "                    \"type\" : \"string\"\r",
                  "                },\r",
                  "                \"qty\" : {\"type\" : \"string\"}\r",
                  "                },\r",
                  "            \"required\" : [\"productId\", \"qty\"]\r",
                  "\r",
                  "        },\r",
                  "        \"state\" : {\r",
                  "            \"type\" : \"string\" \r",
                  "        },\r",
                  "        \"createdAt\" : { \"type\" : \"string\"\r",
                  "        },\r",
                  "        \"updatedAt\" : { \"type\" : \"string\"}\r",
                  "    },\r",
                  "    \"required\" : [\"id\", \"customer\" , \"items\" , \"state\" , \"createdAt\" , \"updatedAt\"]\r",
                  "            }\r",
